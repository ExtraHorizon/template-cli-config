{
  "description": "Mail send when a user changes its email",
  "inputs": {
    "firstname": {
      "type": "string"
    },
    "reset_hash": {
      "type": "string"
    },
    "pin_code": {
      "type": "string"
    },
    "tracking_hash": {
      "type": "string"
    }
  },
  "outputs": {
    "subject": "{{t 'password_reset_subject_v2'}}"
  },
  "variables": {
    "API_HOST": "${API_HOST}"
  },
  "$schema": "https://swagger.extrahorizon.com/cli/1.13.3/config-json-schemas/Template.json"
}
